# --- ApplyOne environment ---
# Copy to .env.local and fill in. Never commit real keys.

# Required: Anthropic API key for parsing, scoring, and generation.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Required for job-URL extraction. 1,000 free credits/month.
# https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Optional: Jina Reader is keyless via https://r.jina.ai/<url>.
# Providing a key raises rate limits. https://jina.ai/reader/
# JINA_API_KEY=jina_...
